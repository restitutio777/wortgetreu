---
interface Props {
  title: string;
  url?: string;
}

const { title, url } = Astro.props;
const shareUrl = url ?? Astro.url.toString();
---

<div class="reading-tools" aria-label="Lese-Werkzeuge">
  <button
    type="button"
    class="rt-btn rt-size"
    data-rt="size"
    title="Schriftgröße"
    aria-label="Schriftgröße ändern"
  >
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M4 19V7a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v12" />
      <path d="M4 13h4" />
      <path d="M13 19V7" />
      <path d="M11 7h4" />
      <path d="M18 11v8" />
      <path d="M15 19h6" />
    </svg>
    <span class="rt-label">A+</span>
  </button>

  <button
    type="button"
    class="rt-btn rt-share"
    data-rt="share"
    data-share-title={title}
    data-share-url={shareUrl}
    title="Teilen oder Link kopieren"
    aria-label="Diesen Text teilen"
  >
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="6" cy="12" r="2.5" />
      <circle cx="17" cy="6" r="2.5" />
      <circle cx="17" cy="18" r="2.5" />
      <path d="M8.2 10.7l6.6-3.4" />
      <path d="M8.2 13.3l6.6 3.4" />
    </svg>
    <span class="rt-label">Teilen</span>
    <span class="rt-toast" aria-hidden="true">Link kopiert</span>
  </button>
</div>

<style>
  .reading-tools {
    display: flex;
    gap: var(--space-2);
    align-items: center;
    justify-content: flex-end;
    margin-bottom: var(--space-4);
  }

  .rt-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--ink-faint);
    padding: 0.4em 0.7em;
    border: 0;
    background: transparent;
    border-radius: 4px;
    cursor: pointer;
    transition: color var(--transition-fast), background var(--transition-fast);
    position: relative;
  }

  .rt-btn:hover {
    color: var(--ink);
    background: var(--paper-sunk);
  }

  .rt-btn[data-active="true"] {
    color: var(--accent);
    background: var(--accent-bg);
  }

  .rt-btn svg {
    flex-shrink: 0;
  }

  .rt-label {
    font-weight: 500;
  }

  .rt-toast {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    padding: 0.4em 0.8em;
    border-radius: 3px;
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition: opacity var(--transition-base), transform var(--transition-base);
    white-space: nowrap;
  }

  .rt-btn[data-toast="true"] .rt-toast {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 540px) {
    .rt-label {
      display: none;
    }
    .rt-btn {
      padding: 0.5em;
    }
  }
</style>

<script>
  const ROOT_KEY = 'wg-textsize';
  const SIZES = ['base', 'lg', 'xl'] as const;
  type Size = (typeof SIZES)[number];

  function applySize(size: Size) {
    document.documentElement.dataset.textsize = size;
    try {
      localStorage.setItem(ROOT_KEY, size);
    } catch {}
  }

  function getCurrent(): Size {
    let stored: string | null = null;
    try {
      stored = localStorage.getItem(ROOT_KEY);
    } catch {}
    if (stored && (SIZES as readonly string[]).includes(stored)) return stored as Size;
    return 'base';
  }

  function nextSize(s: Size): Size {
    const i = SIZES.indexOf(s);
    return SIZES[(i + 1) % SIZES.length];
  }

  // Initialize from storage
  const initial = getCurrent();
  applySize(initial);

  document.querySelectorAll<HTMLButtonElement>('[data-rt="size"]').forEach((btn) => {
    if (initial !== 'base') btn.dataset.active = 'true';
    btn.addEventListener('click', () => {
      const cur = getCurrent();
      const nxt = nextSize(cur);
      applySize(nxt);
      btn.dataset.active = nxt === 'base' ? 'false' : 'true';
      // Update label so user sees state
      const label = btn.querySelector('.rt-label');
      if (label) {
        label.textContent = nxt === 'base' ? 'A+' : nxt === 'lg' ? 'A++' : 'A+++';
      }
    });
    // initialize label for stored size
    if (initial !== 'base') {
      const label = btn.querySelector('.rt-label');
      if (label) label.textContent = initial === 'lg' ? 'A++' : 'A+++';
    }
  });

  document.querySelectorAll<HTMLButtonElement>('[data-rt="share"]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const title = btn.dataset.shareTitle ?? document.title;
      const url = btn.dataset.shareUrl ?? location.href;

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch {
          // user cancelled — fall through to copy
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        btn.dataset.toast = 'true';
        window.setTimeout(() => {
          delete btn.dataset.toast;
        }, 1800);
      } catch {
        window.prompt('Link kopieren:', url);
      }
    });
  });
</script>
