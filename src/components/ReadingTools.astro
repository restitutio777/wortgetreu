---
interface Props {
  title: string;
  url?: string;
}

const { title, url } = Astro.props;
const shareUrl = url ?? Astro.url.toString();
---

<div class="reading-tools" aria-label="Lese-Werkzeuge">
  <button
    type="button"
    class="rt-btn rt-size"
    data-rt="size"
    title="Schriftgröße ändern"
    aria-label="Schriftgröße ändern"
  >
    <span class="rt-glyph rt-glyph-size" aria-hidden="true">
      <span class="g-small">a</span><span class="g-large">A</span>
    </span>
  </button>

  <button
    type="button"
    class="rt-btn rt-share"
    data-rt="share"
    data-share-title={title}
    data-share-url={shareUrl}
    title="Link teilen"
    aria-label="Diesen Text teilen"
  >
    <svg class="rt-glyph" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 14V4" />
      <path d="M8 8l4-4 4 4" />
      <path d="M4 14v5a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-5" />
    </svg>
    <span class="rt-toast" aria-hidden="true">Link kopiert</span>
  </button>
</div>

<style>
  .reading-tools {
    display: flex;
    gap: var(--space-1);
    align-items: center;
    justify-content: flex-end;
    margin-bottom: var(--space-4);
  }

  .rt-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink-faint);
    width: 2rem;
    height: 2rem;
    border: 0;
    background: transparent;
    border-radius: 50%;
    cursor: pointer;
    transition: color var(--transition-fast), background var(--transition-fast);
    position: relative;
  }

  .rt-btn:hover {
    color: var(--ink);
    background: var(--paper-sunk);
  }

  .rt-btn:focus-visible {
    outline: 2px solid var(--focus);
    outline-offset: 2px;
  }

  .rt-btn[data-active="true"] {
    color: var(--accent);
    background: var(--accent-bg);
  }

  /* Größenglyphe: kleines a + großes A */
  .rt-glyph-size {
    font-family: var(--font-serif);
    font-style: italic;
    display: inline-flex;
    align-items: baseline;
    line-height: 1;
    letter-spacing: -0.04em;
  }

  .rt-glyph-size .g-small {
    font-size: 0.85em;
  }

  .rt-glyph-size .g-large {
    font-size: 1.15em;
  }

  /* Größenglyphe wächst mit dem aktuellen Lese-Modus */
  html[data-textsize='lg'] .rt-glyph-size .g-large {
    font-size: 1.3em;
  }

  html[data-textsize='xl'] .rt-glyph-size .g-large {
    font-size: 1.45em;
  }

  .rt-toast {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    font-family: var(--font-sans);
    font-size: 0.7rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    padding: 0.4em 0.8em;
    border-radius: 3px;
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition: opacity var(--transition-base), transform var(--transition-base);
    white-space: nowrap;
  }

  .rt-btn[data-toast="true"] .rt-toast {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const ROOT_KEY = 'wg-textsize';
  const SIZES = ['base', 'lg', 'xl'] as const;
  type Size = (typeof SIZES)[number];

  function applySize(size: Size) {
    document.documentElement.dataset.textsize = size;
    try {
      localStorage.setItem(ROOT_KEY, size);
    } catch {}
  }

  function getCurrent(): Size {
    let stored: string | null = null;
    try {
      stored = localStorage.getItem(ROOT_KEY);
    } catch {}
    if (stored && (SIZES as readonly string[]).includes(stored)) return stored as Size;
    return 'base';
  }

  function nextSize(s: Size): Size {
    const i = SIZES.indexOf(s);
    return SIZES[(i + 1) % SIZES.length];
  }

  // Initialize from storage
  const initial = getCurrent();
  applySize(initial);

  document.querySelectorAll<HTMLButtonElement>('[data-rt="size"]').forEach((btn) => {
    if (initial !== 'base') btn.dataset.active = 'true';
    btn.addEventListener('click', () => {
      const cur = getCurrent();
      const nxt = nextSize(cur);
      applySize(nxt);
      btn.dataset.active = nxt === 'base' ? 'false' : 'true';
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-rt="share"]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const title = btn.dataset.shareTitle ?? document.title;
      const url = btn.dataset.shareUrl ?? location.href;

      if (navigator.share) {
        try {
          await navigator.share({ title, url });
          return;
        } catch {
          // user cancelled — fall through to copy
        }
      }

      try {
        await navigator.clipboard.writeText(url);
        btn.dataset.toast = 'true';
        window.setTimeout(() => {
          delete btn.dataset.toast;
        }, 1800);
      } catch {
        window.prompt('Link kopieren:', url);
      }
    });
  });
</script>
