---
import { PortableText } from 'astro-portabletext';
import type { Werktext } from '../lib/sanity';

interface Props {
  text: Werktext;
}

const { text } = Astro.props;
const form = text.form;
const isLyrik = form === 'gedicht';
const intro = text.intro;
---

<div class:list={['text-body', `text-body--${form}`]}>
  {
    intro && (
      <p class="text-intro">
        <strong>{intro}</strong>
      </p>
    )
  }
  {
    isLyrik && text.gedichtBody && (
      <div class="lyrik-body">{text.gedichtBody}</div>
    )
  }
  {
    !isLyrik && text.prosaBody && (
      <PortableText value={text.prosaBody} />
    )
  }
</div>

<style is:global>
  .text-body p {
    font-family: var(--font-serif);
    color: var(--ink);
    margin-block: 0;
  }

  /* ── Artikel-Intro ─────────────────────────────────────────────────── */
  .text-body--artikel .text-intro {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--ink);
    line-height: 1.5;
    margin-bottom: var(--space-6);
  }
  .text-body--artikel .text-intro strong {
    font-weight: 400;
  }

  /* ── Gedicht ──────────────────────────────────────────────────────── */
  .text-body--gedicht {
    font-family: var(--font-serif);
    font-size: var(--text-poem);
    line-height: var(--lh-poem);
    text-align: center;
    max-width: 36rem;
    margin-inline: auto;
  }

  .text-body--gedicht .lyrik-body {
    white-space: pre-line;
    text-wrap: pretty;
    hyphens: none;
  }

  /* ── Prosa-Formen ─────────────────────────────────────────────────── */
  .text-body--essay,
  .text-body--artikel,
  .text-body--geschichte {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--lh-prose);
  }

  .text-body--essay p,
  .text-body--artikel p,
  .text-body--geschichte p {
    margin-bottom: 1em;
    text-wrap: pretty;
    hyphens: auto;
  }

  .text-body--essay h2,
  .text-body--artikel h2,
  .text-body--geschichte h2 {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
    line-height: var(--lh-tight);
    text-align: left;
  }

  .text-body em {
    font-style: italic;
  }
</style>
