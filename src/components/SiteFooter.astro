---
const jahr = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer-inner">
    <p class="signature">
      <span class="signature-mark" aria-hidden="true">✻</span>
      <span class="signature-name">Katharina Offenborn</span>
      <span class="signature-since">Texte seit 1999</span>
    </p>

    <p class="meta">
      <a href="/impressum">Impressum</a>
      <span class="dot" aria-hidden="true">·</span>
      <a href="/datenschutz">Datenschutz</a>
      <span class="dot" aria-hidden="true">·</span>
      <span class="copy">© {jahr} wortgetreu.com</span>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-10);
    padding-block: var(--space-7) var(--space-7);
    border-top: 1px solid var(--rule);
  }

  .site-footer-inner {
    width: 100%;
    max-width: 36rem;
    margin-inline: auto;
    padding-inline: var(--page-gutter);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    align-items: center;
  }

  .signature {
    font-family: var(--font-serif);
    color: var(--ink);
    line-height: 1.3;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    align-items: center;
  }

  .signature-mark {
    color: var(--ink-faint);
    font-size: 0.85em;
    margin-bottom: var(--space-2);
    line-height: 1;
  }

  .signature-name {
    font-style: italic;
    font-size: var(--text-lg);
  }

  .signature-since {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .meta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
    text-transform: uppercase;
    color: var(--ink-faint);
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: baseline;
    gap: 0.5em;
    line-height: 1.6;
  }

  .meta .dot {
    color: var(--ink-faint);
    opacity: 0.5;
  }

  .meta a {
    border: 0;
    color: var(--ink-soft);
    transition: color var(--transition-fast);
  }

  .meta a:hover {
    color: var(--ink);
  }
</style>
