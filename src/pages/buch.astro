---
import Base from '../layouts/Base.astro';
import { PortableText } from 'astro-portabletext';
import { getBuch } from '../lib/sanity';

const buch = await getBuch();
const title = buch.title ?? 'Leuchtspuren';
const untertitel = buch.untertitel ?? 'Eigenwege in die Zukunft';
const jahr = buch.jahr ?? 2020;
const verlag = buch.verlag ?? 'tredition';
const bestellLink =
  buch.bestellLink ?? 'https://tredition.de/autoren/katharina-offenborn-31976/';
const lead =
  buch.lead ??
  'Eine Sammlung von Texten, die zur Suche nach eigenen Wegen ermutigen.';
---

<Base
  title={`Buch — ${title}`}
  description={`${title} — ${untertitel}. Das Buch von Katharina Offenborn, erschienen ${jahr} bei ${verlag}.`}
  tone="spark"
>
  <article class="buch measure">
    <header class="buch-header">
      <p class="buch-eyebrow sans">Das Buch · {jahr}</p>
      <h1 class="buch-title">
        <span class="buch-main">{title}</span>
        <span class="buch-sub">{untertitel}</span>
      </h1>
      <p class="buch-author">von Katharina&nbsp;Offenborn</p>
    </header>

    <div class="buch-body">
      <p class="lead">{lead}</p>

      <div class="buch-actions">
        <a class="buch-cta" href={bestellLink} target="_blank" rel="noreferrer">
          Beim Verlag bestellen
          <span aria-hidden="true">→</span>
        </a>
        <span class="buch-or sans-sm">oder im Buchhandel deines Vertrauens</span>
      </div>

      <hr class="rule" />

      {buch.beschreibung && <PortableText value={buch.beschreibung} />}
    </div>
  </article>
</Base>

<style>
  .buch {
    padding-block: var(--space-7) var(--space-9);
  }
  .buch-header {
    text-align: center;
    margin-bottom: var(--space-7);
  }
  .buch-eyebrow {
    color: var(--saffron-deep);
    margin-bottom: var(--space-5);
  }
  .buch-title {
    font-family: var(--font-serif);
    font-weight: 400;
    line-height: 1;
    letter-spacing: var(--tracking-display);
    color: var(--ink);
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .buch-main {
    font-size: var(--text-2xl);
    font-variant: small-caps;
    letter-spacing: 0.04em;
  }
  .buch-sub {
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--ink-soft);
    font-weight: 400;
  }
  .buch-author {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-soft);
    font-size: var(--text-base);
  }
  .buch-body {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--lh-prose);
    color: var(--ink);
  }
  .buch-body :global(p) {
    margin-bottom: 1em;
  }
  .buch-body .lead {
    font-size: var(--text-lg);
    font-style: italic;
    color: var(--ink);
    line-height: 1.5;
    margin-bottom: var(--space-5);
  }
  .buch-body :global(h2) {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    font-style: italic;
    color: var(--ink);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    line-height: var(--lh-tight);
  }
  .buch-actions {
    margin-block: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: flex-start;
  }
  .buch-cta {
    border: 0;
    display: inline-flex;
    align-items: baseline;
    gap: 0.5em;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--ink);
    padding-bottom: var(--space-1);
    border-bottom: 1px solid var(--ink);
    transition: color var(--transition-fast), gap var(--transition-base);
  }
  .buch-cta:hover {
    color: var(--accent);
    gap: 0.75em;
    border-bottom-color: var(--accent);
  }
  .buch-or {
    color: var(--ink-soft);
    font-style: italic;
    font-family: var(--font-serif);
    text-transform: none;
    letter-spacing: 0;
  }
</style>
