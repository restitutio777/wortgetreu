---
import Base from '../../layouts/Base.astro';
import TextHeader from '../../components/TextHeader.astro';
import TextBody from '../../components/TextBody.astro';
import ReadingTools from '../../components/ReadingTools.astro';
import { getAlleTexte, urlFor } from '../../lib/sanity';
import type { Werktext } from '../../lib/sanity';

export async function getStaticPaths() {
  const all = await getAlleTexte();
  return all.map((entry, index) => ({
    params: { slug: entry.slug },
    props: {
      entry,
      prev: all[index - 1] ?? null,
      next: all[index + 1] ?? null,
    },
  }));
}

interface Props {
  entry: Werktext;
  prev: Werktext | null;
  next: Werktext | null;
}

const { entry, prev, next } = Astro.props as Props;
const desc = entry.erstzeile ?? `${entry.title} — ${entry.form}`;
const measureClass = entry.form === 'gedicht' ? 'measure measure-poem' : 'measure';
const bildUrl =
  entry.form === 'gedicht' && entry.bild?.asset
    ? urlFor(entry.bild).width(640).height(480).fit('crop').auto('format').url()
    : null;
const bildAlt = entry.bild?.alt ?? entry.title;
---

<Base title={entry.title} description={desc}>
  <article class={measureClass}>
    <ReadingTools title={entry.title} />
    <TextHeader text={entry} />
    {
      bildUrl && (
        <figure class="poem-figure">
          <img src={bildUrl} alt={bildAlt} loading="lazy" decoding="async" width="640" height="480" />
        </figure>
      )
    }
    <TextBody text={entry} />
  </article>

  <hr class="rule measure" />

  <nav class="text-nav measure" aria-label="Im Werk weiterlesen">
    <div class="text-nav-prev">
      {
        prev && (
          <a href={`/werk/${prev.slug}`}>
            <span class="sans">Vorheriger Text</span>
            <span class="title">{prev.title}</span>
          </a>
        )
      }
    </div>
    <div class="text-nav-werk">
      <a href="/werk" class="sans">Werk-Übersicht</a>
    </div>
    <div class="text-nav-next">
      {
        next && (
          <a href={`/werk/${next.slug}`}>
            <span class="sans">Nächster Text</span>
            <span class="title">{next.title}</span>
          </a>
        )
      }
    </div>
  </nav>
</Base>

<style>
  article {
    padding-block: var(--space-4) var(--space-7);
  }

  .poem-figure {
    margin: 0 auto var(--space-6);
    max-width: 22rem;
    text-align: center;
  }

  .poem-figure img {
    width: 100%;
    height: auto;
    border-radius: 2px;
    filter: saturate(0.85);
    box-shadow:
      0 1px 0 var(--rule),
      0 8px 20px -12px oklch(40% 0.05 50 / 0.25);
    transition: filter var(--transition-base);
  }

  .poem-figure img:hover {
    filter: saturate(1);
  }

  @media (min-width: 980px) {
    .poem-figure {
      max-width: 18rem;
    }
  }

  .text-nav {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    padding-block: var(--space-6) var(--space-7);
    align-items: start;
  }

  @media (min-width: 720px) {
    .text-nav {
      grid-template-columns: 1fr auto 1fr;
      align-items: baseline;
    }
  }

  .text-nav a {
    border: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: color var(--transition-fast);
  }

  .text-nav-prev,
  .text-nav-werk,
  .text-nav-next {
    text-align: center;
  }

  @media (min-width: 720px) {
    .text-nav-prev {
      text-align: left;
      align-items: flex-start;
    }
    .text-nav-werk {
      text-align: center;
    }
    .text-nav-next {
      text-align: right;
      align-items: flex-end;
    }
  }

  .text-nav-prev a,
  .text-nav-next a {
    align-items: inherit;
  }

  .text-nav .title {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--ink);
    line-height: 1.3;
    text-wrap: balance;
  }

  .text-nav a:hover .title {
    color: var(--accent);
  }
</style>
