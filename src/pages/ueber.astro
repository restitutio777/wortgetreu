---
import Base from '../layouts/Base.astro';
import { PortableText } from 'astro-portabletext';
import { getUeber } from '../lib/sanity';

const ueber = await getUeber();
const name = ueber.name ?? 'Katharina Offenborn';
const [vorname, ...rest] = name.split(' ');
const nachname = rest.join(' ');
const byline =
  ueber.byline ?? 'Wien, 1959 · Schriftstellerin, Lektorin, Übersetzerin';
const kontakt = ueber.kontaktEmail ?? 'kontakt@wortgetreu.com';
---

<Base
  title={`Über ${name}`}
  description="Wien 1959. Schriftstellerin, Lektorin und Übersetzerin. Lebt als Reisende in mehreren Ländern."
  tone="grow"
>
  <article class="ueber measure">
    <header class="ueber-header">
      <p class="ueber-eyebrow sans">Über</p>
      <h1 class="ueber-title">{vorname}<br />{nachname}</h1>
      <p class="ueber-byline">{byline}</p>
    </header>

    <div class="ueber-body">
      {ueber.lead && <p class="lead">{ueber.lead}</p>}
      {ueber.biografie && <PortableText value={ueber.biografie} />}
    </div>

    <footer class="ueber-foot">
      <p class="sans-sm">
        Kontakt für Anfragen zu Lektorat, Übersetzung oder Lesungen:
        <a href={`mailto:${kontakt}`}>{kontakt}</a>
      </p>
    </footer>
  </article>
</Base>

<style>
  .ueber {
    padding-block: var(--space-7) var(--space-7);
  }
  .ueber-header {
    text-align: center;
    margin-bottom: var(--space-8);
  }
  .ueber-eyebrow {
    color: var(--rose-deep);
    margin-bottom: var(--space-4);
  }
  .ueber-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    color: var(--ink);
    margin-bottom: var(--space-5);
    text-wrap: balance;
  }
  .ueber-byline {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--ink-soft);
    font-size: var(--text-base);
    line-height: 1.4;
  }
  .ueber-body {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    line-height: var(--lh-prose);
    color: var(--ink);
  }
  .ueber-body :global(p) {
    margin-bottom: 1em;
    text-wrap: pretty;
  }
  .ueber-body .lead {
    font-size: var(--text-lg);
    font-style: italic;
    line-height: 1.5;
    color: var(--ink);
    margin-bottom: var(--space-5);
  }
  .ueber-body :global(em) {
    font-style: italic;
  }
  .ueber-foot {
    margin-top: var(--space-8);
    padding-top: var(--space-5);
    border-top: 1px solid var(--rule);
    text-align: center;
  }
  .ueber-foot a {
    color: var(--accent);
    border-bottom-color: var(--rule-strong);
  }
</style>
