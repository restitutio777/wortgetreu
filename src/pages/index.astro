---
import Base from '../layouts/Base.astro';
import { getAllTexte, formatDatum } from '../lib/content';
import { formInfo } from '../content.config';

const alle = await getAllTexte();
const byId = new Map(alle.map((t) => [t.id, t]));

const stillerMomentIds = ['das-unsagbare', 'schutzengel', 'mitleid'];
const schwellenIds = ['krankenhaus', 'schule', 'kathedrale'];
const neueste = alle
  .filter((t) => t.data.jahr && t.data.jahr >= 2024)
  .slice(0, 3);

const stillerMoment = stillerMomentIds.map((id) => byId.get(id)).filter(Boolean);
const schwellen = schwellenIds.map((id) => byId.get(id)).filter(Boolean);
---

<Base
  title="wortgetreu — Werk von Katharina Offenborn"
  description="Lyrik, Essays, Artikel und Geschichten von Katharina Offenborn. Ein Werk seit 1999, gewidmet dem aufmerksamen Wort."
>
  <section class="hero">
    <div class="hero-inner">
      <p class="hero-welcome">Schön, dass du hierher gefunden hast.</p>

      <h1 class="hero-title">
        <em class="verb verb-call">Lass dich</em><br />
        <em class="verb verb-touch">berühren</em>,
        <em class="verb verb-grow">ermutigen</em>,<br />
        <em class="verb verb-spark">inspirieren</em>.
      </h1>

      <p class="hero-subtitle">
        Lyrik, Essays, Artikel und Geschichten von Katharina&nbsp;Offenborn.
      </p>

      <p class="hero-book">
        <a
          href="https://tredition.de/autoren/katharina-offenborn-31976/"
          target="_blank"
          rel="noreferrer"
        >
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 5.5C12 4.4 12.9 3.5 14 3.5h6c.5 0 1 .5 1 1v14c0 .5-.5 1-1 1h-6c-1.1 0-2 .9-2 2"/>
            <path d="M12 5.5C12 4.4 11.1 3.5 10 3.5H4c-.5 0-1 .5-1 1v14c0 .5.5 1 1 1h6c1.1 0 2 .9 2 2"/>
          </svg>
          <span><em>Leuchtspuren</em> bei tredition <span aria-hidden="true">↗</span></span>
        </a>
      </p>
    </div>
  </section>

  <section class="threshold">
    <header class="threshold-intro measure">
      <h2 class="threshold-section-title">Wo möchtest du beginnen?</h2>
    </header>

    <ol class="threshold-list measure-wide">
      <li class="threshold-block" data-variant="touch">
        <header class="threshold-header">
          <p class="threshold-eyebrow sans">
            <span class="numeral">I</span>
            <span>Stille</span>
          </p>
          <h3 class="threshold-title">Für einen stillen Moment</h3>
          <p class="threshold-lead">
            Drei kurze Gedichte, die nicht eilen. Setz dich, atme einmal aus, lies in der Reihenfolge, oder springe.
          </p>
        </header>
        <ol class="thread-list">
          {
            stillerMoment.map((t, i) => (
              t && (
                <li>
                  <a href={`/werk/${t.id}`}>
                    <span class="thread-num">{String(i + 1).padStart(2, '0')}</span>
                    <span class="thread-body">
                      <span class="thread-title">{t.data.title}</span>
                      <span class="thread-preview">{t.data.erstzeile ?? formInfo[t.data.form].label}</span>
                    </span>
                  </a>
                </li>
              )
            ))
          }
        </ol>
      </li>

      <li class="threshold-block" data-variant="grow">
        <header class="threshold-header">
          <p class="threshold-eyebrow sans">
            <span class="numeral">II</span>
            <span>Lesepfad</span>
          </p>
          <h3 class="threshold-title">Schwellen­phänomene</h3>
          <p class="threshold-lead">
            Drei Artikel, 2008 für die Wochenschrift <em>Das Goetheanum</em> geschrieben. Über Orte, an denen sich der Mensch begegnet.
          </p>
        </header>
        <ol class="thread-list">
          {
            schwellen.map((t, i) => (
              t && (
                <li>
                  <a href={`/werk/${t.id}`}>
                    <span class="thread-num">{String(i + 1).padStart(2, '0')}</span>
                    <span class="thread-body">
                      <span class="thread-title">{t.data.title}</span>
                      <span class="thread-preview">
                        {t.data.veroeffentlichtAm ?? formInfo[t.data.form].label}
                      </span>
                    </span>
                  </a>
                </li>
              )
            ))
          }
        </ol>
      </li>

      <li class="threshold-block" data-variant="spark">
        <header class="threshold-header">
          <p class="threshold-eyebrow sans">
            <span class="numeral">III</span>
            <span>Frisch</span>
          </p>
          <h3 class="threshold-title">Neu hinzugekommen</h3>
          <p class="threshold-lead">
            Die jüngsten Texte. Was zuletzt geschrieben wurde.
          </p>
        </header>
        <ol class="thread-list">
          {
            neueste.map((t, i) => (
              <li>
                <a href={`/werk/${t.id}`}>
                  <span class="thread-num">{String(i + 1).padStart(2, '0')}</span>
                  <span class="thread-body">
                    <span class="thread-title">{t.data.title}</span>
                    <span class="thread-preview">
                      {formInfo[t.data.form].label}
                      <span class="dot" aria-hidden="true">·</span>
                      {formatDatum(t)}
                    </span>
                  </span>
                </a>
              </li>
            ))
          }
        </ol>
      </li>
    </ol>

    <p class="threshold-foot sans-sm">
      <a href="/werk">Zum gesamten Werk <span aria-hidden="true">→</span></a>
    </p>
  </section>

  <aside class="services-band">
    <div class="services-inner measure-wide">
      <p class="services-label sans">Auch im Auftrag</p>
      <ul class="services-list">
        <li>Lektorat</li>
        <li>Übersetzung</li>
        <li>Bucherstellung</li>
        <li>Biografien</li>
        <li>Chroniken</li>
        <li>Transkription</li>
      </ul>
      <p class="services-foot">
        Anfragen über <a href="/ueber">Kontakt</a>.
      </p>
    </div>
  </aside>

  <section class="quote-block">
    <blockquote>
      <p class="quote-text">
        Dort, wo uns Poeten die Worte einfallen,<br />
        aufs Wesentliche verdichtet,<br />
        jedes an seinem Platz,<br />
        an jenem geheimen Ort jenseits aller Vernunft,<br />
        lausche ich mit offenem Herzen.
      </p>
      <footer class="quote-attr">
        <a href="/werk/magie-der-poesie">aus <cite>Magie der Poesie</cite></a>
      </footer>
    </blockquote>
  </section>
</Base>

<style>
  .hero {
    padding-inline: var(--page-gutter);
    padding-block: var(--space-7) var(--space-7);
    position: relative;
    background:
      radial-gradient(ellipse 75% 80% at 5% -5%, var(--touch-bg), transparent 55%),
      radial-gradient(ellipse 70% 70% at 50% 110%, var(--grow-bg), transparent 50%),
      radial-gradient(ellipse 75% 80% at 105% -5%, var(--spark-bg), transparent 55%);
  }

  @media (min-width: 720px) {
    .hero {
      padding-block: var(--space-9) var(--space-9);
    }
  }

  .hero-inner {
    max-width: 44rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
  }

  .hero-welcome {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: 1.4;
    color: var(--ink-soft);
    margin-bottom: var(--space-5);
    text-wrap: balance;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: var(--text-display);
    line-height: 1.05;
    letter-spacing: var(--tracking-display);
    color: var(--ink);
    margin-bottom: var(--space-6);
    text-wrap: balance;
  }

  .hero-title .verb {
    font-style: italic;
    font-weight: 400;
  }

  .hero-title .verb-call {
    color: var(--ink-soft);
  }

  .hero-title .verb-touch {
    color: var(--verb-touch);
  }

  .hero-title .verb-grow {
    color: var(--verb-grow);
  }

  .hero-title .verb-spark {
    color: var(--verb-spark);
  }

  .hero-subtitle {
    font-family: var(--font-serif);
    color: var(--ink);
    font-size: var(--text-base);
    line-height: 1.55;
    max-width: 32rem;
    margin-inline: auto;
    text-wrap: pretty;
  }

  /* Buch-Mini im Hero — knappe Zeile mit Icon */
  .hero-book {
    margin-top: var(--space-5);
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: 1.4;
  }

  .hero-book a {
    border: 0;
    color: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    padding: 0.3em 0.7em;
    border-radius: 999px;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .hero-book a svg {
    color: var(--accent);
    transform: translateY(0.5px);
  }

  .hero-book a em {
    font-style: italic;
    color: var(--ink);
  }

  .hero-book a:hover {
    background: var(--accent-bg);
    color: var(--ink);
  }

  /* Services-Band — am Seitenende, ruhig */
  .services-band {
    margin-top: var(--space-9);
    padding-block: var(--space-7);
    padding-inline: var(--page-gutter);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    background: linear-gradient(180deg, transparent, var(--saffron-bg) 50%, transparent);
  }

  .services-inner {
    margin-inline: auto;
    text-align: center;
  }

  .services-label {
    color: var(--saffron-deep);
    margin-bottom: var(--space-4);
  }

  .services-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5em 1.5em;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--ink);
    margin-bottom: var(--space-5);
    line-height: 1.5;
  }

  .services-list li {
    position: relative;
  }

  .services-list li + li::before {
    content: '·';
    position: absolute;
    left: -1em;
    color: var(--ink-faint);
    font-style: normal;
  }

  .services-foot {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    color: var(--ink-soft);
    font-style: italic;
  }

  .services-foot a {
    color: var(--accent);
    border-bottom-color: var(--accent-soft);
  }
  .services-foot a:hover {
    color: var(--accent-deep);
  }

  /* ── Threshold-Sektion ─────────────────────────────────────────────── */
  .threshold {
    padding-block: var(--space-8) var(--space-7);
    padding-inline: var(--page-gutter);
    border-top: 1px solid var(--rule);
    position: relative;
  }

  .threshold-intro {
    text-align: center;
    margin-bottom: var(--space-7);
  }

  .threshold-section-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: var(--text-xl);
    color: var(--ink-soft);
    letter-spacing: 0;
    line-height: 1.2;
  }

  .threshold-list {
    list-style: none;
    display: grid;
    gap: var(--space-5);
    grid-template-columns: 1fr;
    margin-inline: auto;
    padding-inline: 0;
  }

  @media (min-width: 980px) {
    .threshold-list {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-4);
    }
  }

  .threshold-block {
    display: grid;
    grid-template-rows: auto 1fr;
    padding: var(--space-6);
    background: var(--paper-sunk);
    border-radius: 4px;
    position: relative;
    border: 1px solid var(--rule);
  }

  @media (min-width: 980px) {
    .threshold-block {
      padding: var(--space-5);
    }
  }

  .threshold-block[data-variant="touch"] {
    background: linear-gradient(180deg, var(--touch-bg) 0%, var(--paper-sunk) 60%);
    border-color: oklch(85% 0.02 248);
  }

  .threshold-block[data-variant="grow"] {
    background: linear-gradient(180deg, var(--grow-bg) 0%, var(--paper-sunk) 60%);
    border-color: oklch(85% 0.025 20);
  }

  .threshold-block[data-variant="spark"] {
    background: linear-gradient(180deg, var(--spark-bg) 0%, var(--paper-sunk) 60%);
    border-color: oklch(85% 0.035 78);
  }

  .threshold-header {
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule);
  }

  .threshold-eyebrow {
    color: var(--ink-soft);
    margin-bottom: var(--space-3);
    display: flex;
    align-items: baseline;
    gap: 0.7em;
  }

  .threshold-eyebrow .numeral {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.5em;
    line-height: 1;
    letter-spacing: 0;
    text-transform: none;
    font-weight: 400;
  }

  .threshold-block[data-variant="touch"] .threshold-eyebrow .numeral {
    color: var(--touch-deep);
  }

  .threshold-block[data-variant="grow"] .threshold-eyebrow .numeral {
    color: var(--grow-deep);
  }

  .threshold-block[data-variant="spark"] .threshold-eyebrow .numeral {
    color: var(--spark-deep);
  }

  .threshold-block[data-variant="spark"] .thread-num { color: var(--spark-soft); }
  .threshold-block[data-variant="spark"] .thread-list a:hover .thread-title { color: var(--spark-deep); }

  .threshold-title {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: 1.1;
    color: var(--ink);
    text-wrap: balance;
    margin-bottom: var(--space-3);
    letter-spacing: var(--tracking-display);
  }

  .threshold-lead {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-base);
    line-height: 1.45;
    color: var(--ink-soft);
    text-wrap: pretty;
  }

  .thread-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0;
    align-self: end;
  }

  .thread-list li {
    border-bottom: 1px dashed var(--rule-strong);
  }

  .thread-list li:last-child {
    border-bottom: 0;
  }

  .thread-list a {
    display: grid;
    grid-template-columns: 1.6em 1fr;
    gap: var(--space-3);
    padding-block: var(--space-3);
    padding-inline: var(--space-2);
    border: 0;
    align-items: baseline;
    transition: background var(--transition-fast), padding var(--transition-base);
    margin-inline: calc(var(--space-2) * -1);
    border-radius: 3px;
  }

  .thread-list a:hover {
    background: var(--paper);
    padding-inline: var(--space-3);
  }

  .thread-num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-base);
    font-feature-settings: 'tnum' 1;
    color: var(--ink-faint);
    letter-spacing: 0;
    text-align: center;
  }

  .threshold-block[data-variant="touch"] .thread-num { color: var(--touch-soft); }
  .threshold-block[data-variant="grow"] .thread-num { color: var(--grow-soft); }

  .thread-body {
    display: flex;
    flex-direction: column;
    gap: 0.15em;
    min-height: 2.6em;
  }

  .thread-title {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--ink);
    transition: color var(--transition-fast);
    line-height: 1.2;
    font-weight: 500;
  }

  .threshold-block[data-variant="touch"] .thread-list a:hover .thread-title {
    color: var(--touch-deep);
  }
  .threshold-block[data-variant="grow"] .thread-list a:hover .thread-title {
    color: var(--grow-deep);
  }
  .threshold-block[data-variant="spark"] .thread-list a:hover .thread-title {
    color: var(--spark-deep);
  }

  .thread-preview {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-sm);
    color: var(--ink-soft);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .thread-preview .dot {
    color: var(--ink-faint);
    margin-inline: 0.4em;
    font-style: normal;
  }

  .threshold-foot {
    margin-top: var(--space-7);
    text-align: center;
  }

  .threshold-foot a {
    border: 0;
    color: var(--moss);
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
    text-transform: uppercase;
    padding: 0.6em 1.4em;
    transition: color var(--transition-fast), background var(--transition-fast);
    border: 1px solid var(--moss-soft);
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }

  .threshold-foot a:hover {
    color: var(--paper);
    background: var(--moss);
    border-color: var(--moss);
  }

  /* ── Quote ────────────────────────────────────────────────────────── */
  .quote-block {
    padding-block: var(--space-8) var(--space-9);
    padding-inline: var(--page-gutter);
    text-align: center;
    background: linear-gradient(180deg, transparent, var(--grow-bg) 35%, var(--grow-bg) 65%, transparent);
    margin-top: var(--space-6);
  }

  .quote-block blockquote {
    max-width: 36rem;
    margin-inline: auto;
  }

  .quote-text {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: 1.5;
    color: var(--ink);
    margin-bottom: var(--space-5);
    text-wrap: balance;
  }

  @media (min-width: 720px) {
    .quote-text {
      font-size: var(--text-xl);
      line-height: 1.4;
    }
  }

  .quote-attr {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-loose);
    text-transform: uppercase;
    color: var(--violet);
  }

  .quote-attr a {
    border: 0;
    color: inherit;
    transition: color var(--transition-fast);
  }

  .quote-attr a:hover {
    color: var(--violet-deep);
  }

  .quote-attr cite {
    font-style: normal;
    color: var(--ink);
  }
</style>
